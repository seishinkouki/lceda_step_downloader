<hc:Window x:Class="lceda_step_downloader.Views.RootView"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:HelixToolkit="clr-namespace:HelixToolkit.Wpf;assembly=HelixToolkit.Wpf"
           xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
           xmlns:hc="https://handyorg.github.io/handycontrol"
           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
           xmlns:vm="clr-namespace:lceda_step_downloader.ViewModels"
           Title="{Binding Title}"
           Width="760"
           Height="600"
           ShowTitle="True"
           WindowStartupLocation="CenterScreen"
           mc:Ignorable="d">
    <hc:Window.DataContext>
        <vm:RootViewModel />
    </hc:Window.DataContext>
    <Window.Resources>
        <vm:IndexConverter x:Key="MyIndexConverter" />
        <vm:BooleanOrConverter x:Key="MyallowdownloadConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    <Grid Width="{Binding RelativeSource={RelativeSource AncestorType={x:Type Window}}, Path=ActualWidth}" Height="{Binding RelativeSource={RelativeSource AncestorType={x:Type Window}}, Path=ActualHeight}">
        <Grid Grid.Column="0" Margin="0,5,0,28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <hc:ComboBox Grid.Column="0"
                                 Margin="5,0,0,0"
                                 HorizontalAlignment="Stretch"
                                 DisplayMemberPath="Site"
                                 ItemsSource="{Binding SearchSites}"
                                 SelectedItem="{Binding SSite}" />
                    <hc:SearchBar Grid.Column="1"
                                  Margin="5,0,5,0"
                                  HorizontalAlignment="Stretch"
                                  Command="{Binding DoSearchCommand}"
                                  CommandParameter="{Binding Text, RelativeSource={RelativeSource Self}}"
                                  IsRealTime="False" />
                </Grid>
                <Grid Grid.Row="1" Margin="0,0,0,5">
                    <ListView Grid.Row="0"
                              Margin="5,5,5,0"
                              HorizontalAlignment="Stretch"
                              ItemsSource="{Binding SearchResult.result}"
                              SelectedItem="{Binding SelectedItem}">
                        <ListView.Resources>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </Style>
                        </ListView.Resources>
                        <ListView.ItemContainerStyle>
                            <Style BasedOn="{StaticResource ListViewItemBaseStyle}" TargetType="ListViewItem">
                                <Setter Property="MinHeight" Value="20" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="40" DisplayMemberBinding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}, Converter={StaticResource MyIndexConverter}}" />
                                <GridViewColumn Width="Auto" DisplayMemberBinding="{Binding Path=display_title}" />
                                <GridViewColumn Width="Auto" DisplayMemberBinding="{Binding attributes.Manufacturer}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Grid>
            <Grid Grid.Column="1" Margin="0,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="40" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Image Source="{Binding Path=ImageSource}" Stretch="Uniform" />
                    <Border Background="#66FFFFFF"
                            IsHitTestVisible="False"
                            Visibility="{Binding IsImageLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <hc:LoadingCircle Width="40"
                                          Height="40"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          DotDiameter="6"
                                          DotInterval="12" />
                    </Border>
                </Grid>
                <Grid Grid.Row="1">
                    <HelixToolkit:HelixViewport3D IsHeadLightEnabled="False" ZoomExtentsWhenLoaded="True">
                        <HelixToolkit:DefaultLights />
                        <ModelVisual3D Content="{Binding MyModelGroup}" />
                        <HelixToolkit:GridLinesVisual3D Width="8"
                                                        Length="8"
                                                        MajorDistance="1"
                                                        MinorDistance="1"
                                                        Thickness="0.01" />
                    </HelixToolkit:HelixViewport3D>
                    <Border Background="#66FFFFFF"
                            IsHitTestVisible="False"
                            Visibility="{Binding IsObjLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <hc:LoadingCircle Width="40"
                                          Height="40"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          DotDiameter="6"
                                          DotInterval="12"
                                          Style="{StaticResource LoadingBaseStyle}" />
                    </Border>
                </Grid>
                <Grid Grid.Row="2" Margin="0,3,0,10">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="showobj"
                                Height="30"
                                Margin="5,0,5,0"
                                Padding="5,0,5,0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                Command="{Binding DownloadObjCommand}"
                                FontSize="16">
                            <Button.Style>
                                <Style BasedOn="{StaticResource ButtonDefault}" TargetType="Button">
                                    <Setter Property="IsEnabled" Value="True" />
                                    <Setter Property="Content">
                                        <Setter.Value>
                                            <StackPanel Orientation="Horizontal">
                                                <CheckBox Margin="5,0,0,0"
                                                          VerticalAlignment="Center"
                                                          Content="自动|"
                                                          FontSize="16"
                                                          IsChecked="{Binding AutomaticLoadObj}" />
                                                <TextBlock Text="预览模型" />
                                            </StackPanel>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedItem.attributes._3D_Model}" Value="{x:Null}">
                                            <Setter Property="IsEnabled" Value="False" />
                                            <Setter Property="Content" Value="暂无3D模型" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Name="downloadstep"
                                Grid.Column="1"
                                Height="30"
                                MinWidth="100"
                                Margin="0,0,10,0"
                                Padding="5,0,5,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Command="{Binding DownloadStepCommand}">
                            <Button.IsEnabled>
                                <MultiBinding Converter="{StaticResource MyallowdownloadConverter}">
                                    <Binding ElementName="showobj" Path="IsEnabled" />
                                    <Binding Path="DownloadAllowed" />
                                </MultiBinding>
                            </Button.IsEnabled>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="16">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding ElementName=showobj, Path=IsEnabled}" Value="false" />
                                                    </MultiDataTrigger.Conditions>
                                                    <MultiDataTrigger.Setters>
                                                        <Setter Property="Text" Value="暂无3D模型" />
                                                    </MultiDataTrigger.Setters>
                                                </MultiDataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding ElementName=showobj, Path=IsEnabled}" Value="true" />
                                                        <Condition Binding="{Binding Path=DownloadAllowed}" Value="false" />
                                                    </MultiDataTrigger.Conditions>
                                                    <MultiDataTrigger.Setters>
                                                        <Setter Property="Text" Value="下载中" />
                                                    </MultiDataTrigger.Setters>
                                                </MultiDataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding ElementName=showobj, Path=IsEnabled}" Value="true" />
                                                        <Condition Binding="{Binding Path=DownloadAllowed}" Value="true" />
                                                    </MultiDataTrigger.Conditions>
                                                    <MultiDataTrigger.Setters>
                                                        <Setter Property="Text" Value="下载STEP" />
                                                    </MultiDataTrigger.Setters>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
        <ScrollViewer Margin="0,0,0,300"
                      HorizontalAlignment="Right"
                      VerticalScrollBarVisibility="Hidden">
            <StackPanel Margin="0,10,10,10" hc:Growl.GrowlParent="True" />
        </ScrollViewer>
    </Grid>
</hc:Window>
